{
  "version": "1.1.0",
  "description": "Cross-platform terminal tool to inspect and kill processes by port",
  "homepage": "https://github.com/AppestoX/portslayer",
  "license": "MIT",
  "depends": "python",
  "url": "https://files.pythonhosted.org/packages/source/p/portslayer/portslayer-1.1.0.tar.gz#/portslayer-1.1.0.tar.gz",
  "hash": "REPLACE_WITH_SDIST_SHA256_AFTER_PYPI_PUBLISH",
  "notes": "Downloads the PyPI source archive only to verify integrity; the actual install is done by pip so the 'portslayer' console-script shim (and its PATH entry) is managed by Python itself.",
  "post_install": [
    "python -m pip install --upgrade \"portslayer==$version\""
  ],
  "uninstaller": {
    "script": [
      "python -m pip uninstall -y portslayer"
    ]
  },
  "checkver": {
    "url": "https://pypi.org/pypi/portslayer/json",
    "jsonpath": "$.info.version"
  },
  "autoupdate": {
    "url": "https://files.pythonhosted.org/packages/source/p/portslayer/portslayer-$version.tar.gz#/portslayer-$version.tar.gz"
  }
}
